DATABASE_URL="postgresql://USER@localhost:5432/contract_ops_console?schema=public"
PORT=4000
# Comma-separated list of allowed origins for CORS (frontend dev server / deployed frontend URL)
CORS_ORIGIN="http://localhost:5173"
# PDF attachments are stored in S3 (see src/lib/attachmentStorage.ts). Needs
# AWS credentials available via the default SDK chain (e.g. `aws configure`).
S3_BUCKET_NAME=your-attachments-bucket-name
AWS_REGION=us-east-1
