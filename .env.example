# Used by docker-compose (root-level `docker-compose up`) — NOT read by the
# backend/frontend apps directly, they have their own .env files for that.
#
# This must be a Postgres role that can connect to your local Postgres instance
# with no password (Postgres.app's default local trust auth). It's usually your
# OS username — Postgres.app creates a superuser role matching it automatically.
POSTGRES_USER=your_local_postgres_username
